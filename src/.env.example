# Copy to src/.env and fill in. Loaded automatically by game-streamer.sh.

# --- flow 1: setup-steam ---------------------------------------------------
export STEAM_USERNAME=cs2_servers
export STEAM_PASSWORD=

# --- flow 2: run-live ------------------------------------------------------
export MATCH_ID=

# Pick ONE of these two pairs:
# export PLAYCAST_URL=
# - or -
export CONNECT_ADDR=
export CONNECT_PASSWORD=

# --- optional overrides ----------------------------------------------------
# export DEBUG_STREAM_ID=debug
# export FPS=30
# export VIDEO_KBPS=6000
# export STEAM_LIBRARY=/mnt/game-streamer
# export CS2_DIR="$STEAM_LIBRARY/steamapps/common/Counter-Strike Global Offensive"
# export MEDIAMTX_SRT_BASE=srt://mediamtx.5stack.svc.cluster.local:8890
